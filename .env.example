# HouseCodex-Agent unified environment template
#
# This file is a safe inventory of all environment variables used in the repo.
# It is not loaded directly by the application.
#
# Recommended local setup:
#   1. Copy `backend/.env.example` to `backend/.env`
#   2. Copy `frontend/.env.example` to `frontend/.env`
#   3. Fill only your local values into those runtime files

# ----------------------------------------------------------------------
# Backend runtime variables (`backend/.env`)
# ----------------------------------------------------------------------

# API bind address and port
API_HOST=0.0.0.0
API_PORT=8000

# Runtime mode: `development` is local-friendly, `production` enforces required secrets
HOUSE_CODEX_ENV=development

# Legacy dev-mode switch used by the auth verification-code response
APP_ENV=dev

# MySQL DSN format: mysql+pymysql://USER:PASSWORD@HOST:3306/DB?charset=utf8mb4
DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/housecodex?charset=utf8mb4

# Redis DSN format: redis://HOST:6379/DB_INDEX
REDIS_URL=redis://localhost:6379/0

# Chat session cache TTL in seconds
CHAT_CACHE_TTL=3600

# JWT signing secret: use a random string with at least 32 characters
SECRET_KEY=replace_with_a_random_32_plus_character_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Default LLM routing model
DEFAULT_MODEL=deepseek-v3

# SiliconFlow credentials
SILICONFLOW_API_KEY=your_siliconflow_api_key
SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1

# OpenAI credentials, only required when using OpenAI-compatible models
OPENAI_API_KEY=your_openai_api_key_if_used
OPENAI_BASE_URL=https://api.openai.com/v1

# Local vector store path
CHROMA_DB_PATH=./chroma_db

# RongLian SMS credentials, optional when using mock SMS in local development
RONGLIAN_ACCOUNT_SID=your_ronglian_account_sid_if_used
RONGLIAN_AUTH_TOKEN=your_ronglian_auth_token_if_used
RONGLIAN_APP_ID=your_ronglian_app_id_if_used
RONGLIAN_BASE_URL=https://app.cloopen.com:8883
RONGLIAN_TEMPLATE_ID=1

# Local seed-account passwords
ADMIN_SEED_PASSWORD=replace_admin_seed_password
LANDLORD_SEED_PASSWORD=replace_landlord_seed_password
USER_SEED_PASSWORD=replace_user_seed_password

# Retrieval and notification tuning
SIMILARITY_THRESHOLD=0.5
SMS_RATE_LIMIT_PER_HOUR=5
VERIFICATION_CODE_TTL=300

# ----------------------------------------------------------------------
# Frontend runtime variables (`frontend/.env`)
# ----------------------------------------------------------------------

# Browser-side base URL for API requests. Never store secrets in `VITE_*`.
VITE_API_BASE=/api

# Vite dev proxy target for local development
VITE_DEV_BACKEND=http://localhost:8000
