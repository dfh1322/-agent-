# ────────────────────────────────────────────────────────────────────────
# HouseCodex-Agent — 后端环境变量契约（占位模板，提交到仓库）
#
# 实际部署时建议复制到 backend/.env 并填入真实值。backend/.env 已被
# .gitignore 排除，不会被意外提交。
#
# 关键规则：
#   * 若不是 HOUSE_CODEX_ENV=development，缺失下列任何强校验字段都会让
#     应用启动失败：
#       - SECRET_KEY
#       - DATABASE_URL
#       - SILICONFLOW_API_KEY（如使用 LLM，默认必填）
#       - ADMIN_SEED_PASSWORD / LANDLORD_SEED_PASSWORD / USER_SEED_PASSWORD
#     这避免了源码字面量兜底（CLAUDE.md §9）。
# ────────────────────────────────────────────────────────────────────────

# API 配置
API_HOST=0.0.0.0
API_PORT=8000

# 运行模式（development / production；缺省 production）
HOUSE_CODEX_ENV=development

# MySQL（必填）
DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/housecodex?charset=utf8mb4

# Redis（必填，失败时降级到内存）
REDIS_URL=redis://localhost:6379/0

# JWT（必填；HS256 + >=32 字节随机字符串）
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM 默认模型（deepseek-v3 / qwen-...）
DEFAULT_MODEL=deepseek-v3

# SiliconFlow（必填，除非切换到 OpenAI）
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1

# OpenAI（可选，仅在切换到 OpenAI 时使用）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ChromaDB 持久化路径
CHROMA_DB_PATH=./chroma_db

# 容联云短信（可选；缺失时自动降级 mock，仅打印验证码到日志，不发送真实短信）
RONGLIAN_ACCOUNT_SID=
RONGLIAN_AUTH_TOKEN=
RONGLIAN_APP_ID=
RONGLIAN_BASE_URL=https://app.cloopen.com:8883
RONGLIAN_TEMPLATE_ID=1

# 种子账号密码（必填；HOUSE_CODEX_ENV=development 时可省略）
ADMIN_SEED_PASSWORD=
LANDLORD_SEED_PASSWORD=
USER_SEED_PASSWORD=

# 幻觉防控：检索相似度阈值（0~1，越高越严格；默认 0.5）
SIMILARITY_THRESHOLD=0.5
