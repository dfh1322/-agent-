# ----------------------------------------------------------------------
# HouseCodex-Agent backend environment template
#
# Usage:
#   Copy this file to `backend/.env` and fill in your local or deployment values.
#   `backend/.env` is ignored by the repository root `.gitignore`.
#
# Key rule:
#   When `HOUSE_CODEX_ENV` is not `development`, the backend will require
#   real values for `SECRET_KEY`, `DATABASE_URL`, the active LLM provider key,
#   and the three seed-account passwords at startup.
# ----------------------------------------------------------------------

# API 服务监听地址
API_HOST=0.0.0.0
API_PORT=8000

# 运行模式（development / production；缺省 production）
HOUSE_CODEX_ENV=development

# 兼容旧逻辑的开发模式开关（验证码接口会读取）
APP_ENV=dev

# MySQL（必填）
DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/housecodex?charset=utf8mb4

# Redis（可选，未配置时默认本机；连接失败时会降级到内存）
REDIS_URL=redis://localhost:6379/0

# ChatCache TTL（秒）
CHAT_CACHE_TTL=3600

# JWT（必填；HS256 + >=32 字节随机字符串）
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM 默认模型（deepseek-v3 / qwen-...）
DEFAULT_MODEL=deepseek-v3

# SiliconFlow（必填，除非切换到 OpenAI）
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1

# OpenAI（可选，仅在切换到 OpenAI 时使用）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ChromaDB 持久化路径
CHROMA_DB_PATH=./chroma_db

# 容联云短信（可选；缺失时自动降级 mock，仅打印验证码到日志，不发送真实短信）
RONGLIAN_ACCOUNT_SID=
RONGLIAN_AUTH_TOKEN=
RONGLIAN_APP_ID=
RONGLIAN_BASE_URL=https://app.cloopen.com:8883
RONGLIAN_TEMPLATE_ID=1

# 种子账号密码（必填；HOUSE_CODEX_ENV=development 时可省略）
ADMIN_SEED_PASSWORD=
LANDLORD_SEED_PASSWORD=
USER_SEED_PASSWORD=

# 幻觉防控：检索相似度阈值（0~1，越高越严格；默认 0.5）
SIMILARITY_THRESHOLD=0.5

# 单手机号每小时短信发送上限（默认 5）
SMS_RATE_LIMIT_PER_HOUR=5

# 验证码有效期（秒，默认 300）
VERIFICATION_CODE_TTL=300
